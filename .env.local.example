# Clerk - https://clerk.com/docs/quickstarts/nextjs
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...

# Clerk redirect URLs (opcionális, ha a default nem megfelelő)
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/

# Google Sheets - service account JSON (minified, egysoros)
GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}

# Google Sheets dokumentum ID (az URL-ből: /spreadsheets/d/<ID>/edit)
GOOGLE_SHEETS_ID=1abc...xyz

# Resend email - https://resend.com (opcionális)
RESEND_API_KEY=re_...
RESEND_FROM_EMAIL=szodarab@yourdomain.com
